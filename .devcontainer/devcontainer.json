{
    "name" : "market-stream-development",
    "dockerComposeFile": "docker-compose.yaml",
    "service": "market-stream-dev-container",

    "runArgs": [
        "--name", "market-stream-development",
        "--rm",
        "--cap-add=SYS_PTRACE",
        "--security-opt", "seccomp=unconfined"
    ],

    "build": {
        "options": ["--pull=false"]
    },

    "features": {
        "ghcr.io/devcontainers/features/common-utils": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "installOhMyZsh": true
        }
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "vadimcn.vscode-lldb"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            }

        }
    },
    "remoteUser": "root",
    "workspaceFolder": "/work",
    "mounts": [
        "source=${localWorkspaceFolder},target=/work,type=bind"
    ],
    "postCreateCommand": "git clone https://github.com/zsh-users/zsh-autosuggestions.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions && git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting && sed -i 's/plugins=(git)/plugins=(git zsh-autosuggestions zsh-syntax-highlighting)/' ~/.zshrc"
}
